# ========================
# Application Configuration
# ========================
APP_NAME=Document Chatbot
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ========================
# Authentication & Security
# ========================
JWT_SECRET_KEY=replace-with-a-long-random-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
USER_DB_PATH=storage/users.db
PASSWORD_MIN_LENGTH=8

# CORS - comma-separated list
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# ========================
# Embedding Provider
# ========================
# Options: openai or huggingface
EMBEDDING_PROVIDER=huggingface
HF_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSION=1536

# ========================
# LLM Configuration
# ========================
GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# ========================
# Vector Database Backend
# ========================
# Options: chroma, pinecone, or qdrant
VECTOR_BACKEND=chroma

# Chroma Configuration
CHROMA_DIR=storage/chroma

# Pinecone Configuration
PINECONE_API_KEY=
PINECONE_INDEX=
PINECONE_NAMESPACE_PREFIX=doc-chat

# Qdrant Configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=doc_chat

# ========================
# Storage Configuration
# ========================
UPLOAD_DIR=storage/uploads
INDEX_STATE_PATH=storage/index_state.json
JOB_STATE_PATH=storage/jobs_state.json
MAX_UPLOAD_SIZE_MB=50

# ========================
# RAG Configuration
# ========================
TOP_K=5
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
ENABLE_QUERY_REWRITE=true
ENABLE_HYBRID_SEARCH=true
ENABLE_QUERY_EXPANSION=true
QUERY_EXPANSION_VARIANTS=3

# ========================
# Rate Limiting
# ========================
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD_SECONDS=60

# ========================
# Request Timeouts
# ========================
REQUEST_TIMEOUT_SECONDS=120
UPLOAD_TIMEOUT_SECONDS=300
SQLITE_TIMEOUT_SECONDS=5

# ========================
# Logging
# ========================
LOG_LEVEL=INFO

# ========================
# Frontend Configuration
# ========================
API_BASE_URL=http://localhost:8000/api
STREAMLIT_PORT=8501
